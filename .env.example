# Copy this file to .env and fill in your real values.
# Never commit the real .env. It is gitignored.

# Required: your Anthropic API key.
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: Supabase over HTTPS. If you leave these blank, the app uses an
# in-memory store that resets on restart. Get these from your Supabase
# project: Settings -> API. Use the project URL and the anon public key.
SUPABASE_URL=
SUPABASE_KEY=
